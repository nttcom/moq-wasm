graph TB
    subgraph "relay crate"
        subgraph "relay_server層<br>【役割】外部公開APIとサーバ全体の起動・組み立て"
            RelayServer["RelayServer<br>─────────────────────────────<br>【役割】リレーサーバのエントリポイント。<br>RelayStore・RelayRuntime を生成し<br>spawn_transport() でトランスポートを起動する"]
            RelayStore["RelayStore<br>─────────────────────────────<br>【役割】グローバルな共有リソースのArc保持場所。<br>TrackCacheStore と SenderMap を持つ"]
            RelayRuntime["RelayRuntime<br>─────────────────────────────<br>【役割】IngressCoordinator・EgressCoordinator・<br>EventHandler をまとめて生存させる構造体。<br>Drop時に全タスクが停止する"]
        end

        subgraph "session管理層<br>【役割】クライアント接続の受付とセッション生存管理"
            SessionHandler["SessionHandler<br>─────────────────────────────<br>【役割】moqt::Endpoint を使い接続をacceptし続ける<br>tokio task。新規Sessionを SessionRepository へ登録する"]
            SessionRepository["SessionRepository<br>─────────────────────────────<br>【役割】SessionId → Arc&lt;dyn Session&gt; を管理する。<br>Session追加時に SessionEvent 受信ループを起動し<br>イベントを MOQTMessageReceived チャネルへ流す"]
            ThreadManager["ThreadManager<br>─────────────────────────────<br>【役割】SessionId に紐づく JoinHandle を保持し<br>Drop時に全タスクを abort する"]
            MOQTSessionEventResolver["MOQTSessionEventResolver<br>─────────────────────────────<br>【役割】moqt::SessionEvent を<br>relayクレート内の MOQTMessageReceived に変換する"]
        end

        subgraph "イベント処理層<br>【役割】受信したシグナリングイベントをシーケンス処理へ振り分ける"
            EventHandler["EventHandler<br>─────────────────────────────<br>【役割】MOQTMessageReceived を受信し<br>Publish/Subscribe 等の各シーケンスを呼び出す<br>tokio task として常時動作する"]
            MOQTMessageReceived["MOQTMessageReceived (enum)<br>─────────────────────────────<br>PublishNameSpace / SubscribeNameSpace<br>Publish / Subscribe / GoAway"]
        end

        subgraph "sequences層<br>【役割】MoQT シグナリングのビジネスロジックと状態管理"
            Sequences["Publish / Subscribe<br>PublishNamespace / SubscribeNamespace<br>─────────────────────────────<br>【役割】各シグナリングのハンドリングロジック。<br>Table を参照してセッションを解決し<br>Notifier 経由で応答を返す"]
            Notifier["Notifier<br>─────────────────────────────<br>【役割】SessionRepository を介して<br>対象セッションへ応答メッセージを送る"]
            Table["Table / HashMapTable<br>─────────────────────────────<br>【役割】namespace/track → SessionId の<br>マッピングを管理する状態テーブル"]
        end

        subgraph "relay (データ転送)層<br>【役割】Publisher→Cacheへの受信とCache→Subscriberへの配信を担う"
            IngressCoordinator["IngressCoordinator<br>─────────────────────────────<br>【役割】Publisher側の受信タスクを起動する。<br>stream/datagram それぞれの受信タスクへ<br>起動リクエストを振り分ける"]
            StreamIngressTask["StreamIngressTask<br>─────────────────────────────<br>【役割】Publisherのユニディレクショナルストリームを<br>受信し TrackCache へ書き込む"]
            DatagramReader["DatagramReader<br>─────────────────────────────<br>【役割】Publisherのデータグラムを受信し<br>TrackCache へ書き込む"]
            EgressCoordinator["EgressCoordinator<br>─────────────────────────────<br>【役割】Subscriber側の配信タスクを起動する。<br>EgressRunner を JoinSet で管理する"]
            EgressRunner["EgressRunner<br>─────────────────────────────<br>【役割】TrackCache からデータを読み出し<br>Scheduler/GroupSender 経由で<br>Subscriber へ配信する"]
            TrackCacheStore["TrackCacheStore<br>─────────────────────────────<br>【役割】TrackKey → TrackCache のストア。<br>get_or_create() で都度キャッシュを確保する"]
            TrackCache["TrackCache<br>─────────────────────────────<br>【役割】group_id 単位のオブジェクトデータを<br>保持するキャッシュ。Ingress が書き Egress が読む"]
            SenderMap["SenderMap<br>─────────────────────────────<br>【役割】TrackKey → 通知チャネル のマップ。<br>新規データ到着をEgressへ通知する"]
        end

        subgraph "core層<br>【役割】moqt crate のAPIをrelayクレート向けにラップ"
            CoreSession["Session trait<br>Publisher / Subscriber"]
        end
    end

    %% relay_server 組み立て
    RelayServer -->|生成・保持| RelayStore
    RelayServer -->|生成・保持| RelayRuntime
    RelayServer -->|"spawn_transport()"| SessionHandler
    RelayRuntime -->|束ねる| IngressCoordinator
    RelayRuntime -->|束ねる| EgressCoordinator
    RelayRuntime -->|束ねる| EventHandler

    %% 接続受付
    SessionHandler -->|"accept() → add()"| SessionRepository
    SessionRepository -->|保持| ThreadManager
    SessionRepository -->|変換| MOQTSessionEventResolver
    MOQTSessionEventResolver -->|送信| MOQTMessageReceived

    %% イベント振り分け
    MOQTMessageReceived -->|受信| EventHandler
    EventHandler -->|呼び出し| Sequences
    EventHandler -->|Publish確定時| IngressCoordinator
    EventHandler -->|Subscribe確定時| EgressCoordinator
    Sequences -->|応答| Notifier
    Sequences -->|参照・更新| Table
    Notifier -->|セッション検索| SessionRepository

    %% データ転送
    IngressCoordinator -->|起動| StreamIngressTask
    IngressCoordinator -->|起動| DatagramReader
    StreamIngressTask -->|書き込み| TrackCache
    DatagramReader -->|書き込み| TrackCache
    TrackCache -->|内包| TrackCacheStore
    StreamIngressTask -->|到着通知| SenderMap
    DatagramReader -->|到着通知| SenderMap
    EgressCoordinator -->|起動| EgressRunner
    EgressRunner -->|読み出し| TrackCache
    EgressRunner -->|到着待機| SenderMap

    %% core
    SessionRepository -->|利用| CoreSession
    IngressCoordinator -->|利用| CoreSession
    EgressCoordinator -->|利用| CoreSession
