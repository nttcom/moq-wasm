# ONVIF credentials for Makefile targets
ONVIF_IP=
ONVIF_USERNAME=
ONVIF_PASSWORD=

# MoQ bridge
MOQT_URL=https://localhost:4433

# OpenTelemetry / otel-lgtm
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# Optional: set when your OTLP backend requires request metadata.
# Example: OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer%20your-token
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=relay
OTEL_SDK_DISABLED=false

# Logging filters
RELAY_STDOUT_FILTER=relay=info,moqt=info
RELAY_OTEL_FILTER=relay=info,moqt=info
RELAY_LOG_FILTER=relay=info,moqt=info
