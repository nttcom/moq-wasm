# ONVIF credentials for Makefile targets
ONVIF_IP=
ONVIF_USERNAME=
ONVIF_PASSWORD=

# MoQ bridge
MOQT_URL=https://localhost:4433

# OpenTelemetry / OTLP SaaS backend, for example Honeycomb.
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io
# Set headers required by your backend.
# Honeycomb example:
# OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=your-api-key,x-honeycomb-dataset=moqt-relay
OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=your-api-key,x-honeycomb-dataset=moqt-relay
OTEL_SERVICE_NAME=relay
OTEL_SDK_DISABLED=false

# Logging filters
RELAY_STDOUT_FILTER=relay=info,moqt=info
RELAY_OTEL_FILTER=relay=info,moqt=info
RELAY_LOG_FILTER=relay=info,moqt=info
